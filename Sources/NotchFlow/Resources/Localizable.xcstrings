{
  "sourceLanguage": "en",
  "strings": {
    "\"%@\" is unavailable. Remove the shortcut from the shelf and add it again.": {
      "localizations": {
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "„%@” jest niedostępny. Usuń skrót z półki i dodaj go ponownie."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "„%@“ ist nicht verfügbar. Entferne die Verknüpfung aus der Ablage und füge sie erneut hinzu."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "«%@» non è disponibile. Rimuovi la scorciatoia dalla mensola e aggiungila di nuovo."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "«%@» no está disponible. Quita el acceso directo de la bandeja y añádelo de nuevo."
          }
        }
      }
    },
    "25 min work · 5 min break": {
      "localizations": {
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "25 min pracy · 5 min przerwy"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "25 Min. Arbeit · 5 Min. Pause"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "25 min lavoro · 5 min pausa"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "25 min trabajo · 5 min descanso"
          }
        }
      }
    },
