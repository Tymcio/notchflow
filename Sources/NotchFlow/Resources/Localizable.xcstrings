    "NotchFlow narrows the left idle wing when the active app's menu bar reaches the notch.": {
      "localizations": {
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "NotchFlow zwęża lewe skrzydełko wyspy idle, gdy menu aktywnej aplikacji podchodzi pod notch."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NotchFlow verengt den linken Idle-Flügel, wenn die Menüleiste der aktiven App die Notch erreicht."
