    "Calendar and other tabs adjust height to content automatically.": {
      "localizations": {
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kalendarz i pozostałe zakładki dopasowują wysokość do treści automatycznie."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
