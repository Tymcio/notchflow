    "Stores recent copied text and links locally. Passwords and concealed pasteboard entries are skipped. Off by default.": {
      "localizations": {
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zapisuje lokalnie ostatnie skopiowane teksty i linki. Hasła i ukryte wpisy ze schowka są pomijane. Domyślnie wyłączone."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Speichert zuletzt kopierte Texte und Links lokal. Passwörter und verdeckte Zwischenablageeinträge werden übersprungen. Standardmäßig aus."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Salva localmente testi e link copiati di recente. Password e voci nascoste degli appunti vengono ignorate. Disattivato di default."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Guarda localmente textos y enlaces copiados recientemente. Se omiten contraseñas y entradas ocultas del portapapeles. Desactivado por defecto."
