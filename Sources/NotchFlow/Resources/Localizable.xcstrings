    "API running locally on this Mac": {
      "localizations": {
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "API działa lokalnie na tym Macu"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "API läuft lokal auf diesem Mac"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "API in esecuzione localmente su questo Mac"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "API ejecutándose localmente en este Mac"
          }
        }
      }
    },
    "Accessibility is enabled — NotchFlow can read system notification banners.": {
      "localizations": {
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dostępność jest włączona — NotchFlow może odczytywać bannery powiadomień systemowych."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bedienungshilfen sind aktiv — NotchFlow kann System-Mitteilungsbanner lesen."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Accessibilità attiva — NotchFlow può leggere i banner di notifica di sistema."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Accesibilidad activada — NotchFlow puede leer banners de notificaciones del sistema."
          }
        }
      }
    },
    "Accessibility permission is required to detect calls and Notification Center alerts.": {
      "localizations": {
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wymagane uprawnienie Dostępności, aby wykrywać połączenia i powiadomienia z Notification Center."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bedienungshilfen sind erforderlich, um Anrufe und Mitteilungszentrale-Banner zu erkennen."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Serve Accessibilità per rilevare chiamate e avvisi del Centro notifiche."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se requiere Accesibilidad para detectar llamadas y avisos del Centro de notificaciones."
          }
        }
      }
    },
    "Accessibility permission is required to detect the app menu position.": {
      "localizations": {
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wymagane uprawnienie Dostępności, aby wykrywać pozycję menu aplikacji."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bedienungshilfen sind erforderlich, um die Menüposition der App zu erkennen."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Serve il permesso Accessibilità per rilevare la posizione del menu app."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se requiere Accesibilidad para detectar la posición del menú de la app."
          }
        }
      }
    },
    "Activate license": {
      "localizations": {
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktywuj licencję"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lizenz aktivieren"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Attiva licenza"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Activar licencia"
          }
        }
      }
    },
    "Activate your license in Settings → License, then return here.": {
      "localizations": {
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktywuj licencję w Ustawienia → Licencja, a potem wróć tutaj."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktiviere deine Lizenz unter Einstellungen → Lizenz und kehre dann hierher zurück."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Attiva la licenza in Impostazioni → Licenza, poi torna qui."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Activa tu licencia en Ajustes → Licencia y vuelve aquí."
          }
        }
      }
    },
