    "Activation limit reached for this key (max. 2 Macs).": {
      "localizations": {
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Osiągnięto limit aktywacji dla tego klucza (maks. 2 Maci)."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktivierungslimit für diesen Schlüssel erreicht (max. 2 Macs)."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Limite attivazioni raggiunto per questa chiave (max 2 Mac)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Límite de activaciones alcanzado para esta clave (máx. 2 Mac)."
          }
        }
      }
    },
    "Activation released in Polar. You can activate the key on another Mac.": {
      "localizations": {
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktywacja została zwolniona w Polar. Możesz aktywować klucz na innym Macu."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktivierung in Polar freigegeben. Du kannst den Schlüssel auf einem anderen Mac aktivieren."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Attivazione rilasciata in Polar. Puoi attivare la chiave su un altro Mac."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Activación liberada en Polar. Puedes activar la clave en otro Mac."
          }
        }
      }
    },
