    "When disabled, other apps cannot control NotchFlow via notchflow://. Camera mirror requires additional confirmation.": {
      "localizations": {
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gdy wyłączone, inne aplikacje nie mogą sterować NotchFlow przez adres notchflow://. Lustro kamery wymaga dodatkowego potwierdzenia."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn deaktiviert, können andere Apps NotchFlow nicht über notchflow:// steuern. Kameraspiegel erfordert zusätzliche Bestätigung."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Se disattivato, altre app non possono controllare NotchFlow via notchflow://. Lo specchio della fotocamera richiede conferma aggiuntiva."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si está desactivado, otras apps no pueden controlar NotchFlow vía notchflow://. El espejo de cámara requiere confirmación adicional."
          }
        }
      }
    },
    "Without Accessibility, a fallback zone along the top edge is used. For the fastest response, enable NotchFlow in System Settings → Privacy → Accessibility.": {
      "localizations": {
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bez Dostępności działa tryb zapasowy nad górną krawędzią ekranu. Dla najszybszej reakcji włącz NotchFlow w Ustawienia → Prywatność → Dostępność."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ohne Bedienungshilfen wird ein Ersatzbereich am oberen Bildschirmrand verwendet. Für die schnellste Reaktion aktiviere NotchFlow unter Systemeinstellungen → Datenschutz → Bedienungshilfen."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Senza Accessibilità viene usata una zona di riserva sul bordo superiore. Per la risposta più rapida, abilita NotchFlow in Impostazioni di Sistema → Privacy → Accessibilità."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sin Accesibilidad se usa una zona de respaldo en el borde superior. Para la respuesta más rápida, activa NotchFlow en Ajustes del Sistema → Privacidad → Accesibilidad."
          }
        }
      }
    }
  },
  "version": "1.0"
}
