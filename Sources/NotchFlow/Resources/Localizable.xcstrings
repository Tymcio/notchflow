    "Beta period — all Premium features are unlocked without a key.": {
      "localizations": {
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Okres beta — wszystkie funkcje Premium są odblokowane bez klucza."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beta-Phase — alle Premium-Funktionen sind ohne Schlüssel freigeschaltet."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Periodo beta — tutte le funzioni Premium sono sbloccate senza chiave."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Periodo beta — todas las funciones Premium están desbloqueadas sin clave."
          }
        }
      }
    },
    "Beta period — all Premium features are unlocked. A key will be required in the stable release; any key entered now will be remembered.": {
      "localizations": {
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Okres beta — wszystkie funkcje Premium są odblokowane. Aktywacja klucza będzie wymagana w wersji stabilnej; wpisany teraz klucz zostanie zapamiętany."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beta-Phase — alle Premium-Funktionen sind freigeschaltet. Ein Schlüssel wird in der stabilen Version erforderlich sein; ein jetzt eingegebener Schlüssel wird gespeichert."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Periodo beta — tutte le funzioni Premium sono sbloccate. Una chiave sarà richiesta nella versione stabile; una chiave inserita ora verrà memorizzata."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Periodo beta — todas las funciones Premium están desbloqueadas. Se requerirá clave en la versión estable; cualquier clave introducida ahora se recordará."
          }
        }
      }
    },
